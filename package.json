{
  "name": "dev-fortune",
  "version": "1.0.0",
  "description": "Developer fortune cookies - inspirational quotes for your terminal",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "dev-fortune": "./bin/dev-fortune"
  },
  "files": [
    "bin/",
    "src/",
    "data/",
    "quotes.json",
    "README.md"
  ],
  "scripts": {
    "start": "node src/cli.js",
    "dev": "node bin/dev-fortune",
    "start:server": "node server/index.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/jest --coverage",
    "tui": "node src/tui/index.js",
    "start:slack": "node integrations/slack/bot.js",
    "start:discord": "node integrations/discord/bot.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mongsill6/dev-fortune.git"
  },
  "keywords": [
    "cli",
    "fortune",
    "quotes",
    "developer",
    "terminal",
    "inspiration",
    "programming",
    "nodejs",
    "i18n",
    "multilingual"
  ],
  "author": "mongsill6",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/mongsill6/dev-fortune/issues"
  },
  "homepage": "https://github.com/mongsill6/dev-fortune#readme",
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "boxen": "^5.1.2",
    "chalk": "^4.1.2",
    "commander": "^12.0.0",
    "esbuild": "^0.27.4",
    "express": "^5.2.1",
    "ink": "^6.8.0",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "js-yaml": "^4.1.0",
    "react": "^19.2.4",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "@slack/bolt": "^4.1.0",
    "discord.js": "^14.18.0",
    "dotenv": "^16.5.0",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "jest": "^30.3.0"
  }
}
